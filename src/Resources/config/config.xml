<?xml version="1.0" encoding="UTF-8"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>SanalPosPro API Configuration</title>
        <title lang="de-DE">SanalPosPro API-Konfiguration</title>

        <input-field type="text">
            <name>publicApiKey</name>
            <label>Public API Key</label>
            <label lang="de-DE">Öffentlicher API-Schlüssel</label>
            <helpText>Your PayThor public API key (App ID: 106)</helpText>
        </input-field>

        <input-field type="password">
            <name>secretApiKey</name>
            <label>Secret API Key</label>
            <label lang="de-DE">Geheimer API-Schlüssel</label>
            <helpText>Your PayThor secret API key</helpText>
        </input-field>

        <input-field type="password">
            <name>webhookSecret</name>
            <label>Webhook Secret</label>
            <label lang="de-DE">Webhook-Geheimnis</label>
            <helpText>Used to verify HMAC-SHA256 signatures on incoming webhook payloads</helpText>
        </input-field>
    </card>

</config>
